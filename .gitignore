# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Environment / secrets
.env
.env.*
!.env.example

# Local-only scratch — never committed
.git-ignored/*
!.git-ignored/README.md

# Projects directory: ignore contents by default.
# - Clone external repos here; their own .git keeps them isolated.
# - Or register them as submodules (tracked via .gitmodules).
# - Or use `git add -f <path>` / per-path `!` exceptions to track in-tree work.
projects/*
!projects/README.md
