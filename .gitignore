# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Environment / secrets
.env
.env.*
!.env.example

# Local-only scratch — never committed
.git-ignored/*
!.git-ignored/README.md

# Git worktrees created for work in projects/<name>/ repos. Worktrees
# live at $OVERMIND_ROOT/.git-worktrees/ so they sit outside any
# individual project's working tree.
.git-worktrees/

# Generated by scripts/overmind for the gemini backend (assembled system prompt).
GEMINI.md

# Speckit writes a stub here (init-options.json: context_file=CLAUDE.md). The
# overmind launcher feeds Claude via --append-system-prompt instead, so this
# file is purely a local speckit artifact — never committed.
CLAUDE.md

# Claude Code local artifacts (settings.local.json, session/history files,
# etc.). Only the skills symlink is tracked.
.claude/*
!.claude/skills

# Projects directory: ignore contents by default.
# - Clone external repos here; their own .git keeps them isolated.
# - Or register them as submodules (tracked via .gitmodules).
# - Or use `git add -f <path>` / per-path `!` exceptions to track in-tree work.
projects/*
!projects/README.md

# Private memory repo, mounted as a clone at memory/private/. Its contents
# are tracked in the separate `overmind-private-memory` repo, never here.
memory/private/

# JS / Bun
node_modules/

# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.pyright/

# Build outputs
dist/
build/
